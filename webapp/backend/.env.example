# Starknet RPC endpoint. Used both for prover-internal nonce lookups and for
# submitting the register_fact transaction.
RPC_URL=https://starknet-sepolia.public.blastapi.io

# Proving service JSON-RPC base URL.
PROVING_SERVICE_URL=http://34.29.249.119:30001

# Relayer account that signs and pays gas for register_fact. Anyone can
# register a fact as long as they hand in a valid proof — but the tx still
# needs a Starknet account to flow through.
RELAYER_ADDRESS=0x0
RELAYER_PRIVATE_KEY=0x0

# How many blocks to wait between currentBlock and the virtual base block.
# The privacy SDK convention is 10. Lower means fresher state, more reorg risk.
PROVING_BLOCK_OFFSET=10

# CORS origin — the frontend's URL. Use `*` to allow all (dev only).
CORS_ORIGIN=http://localhost:5173

PORT=8787
