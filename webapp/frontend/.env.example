# Public RPC endpoint for read calls (balance, decimals, events). Sepolia by default.
VITE_RPC_URL=/api/rpc

# Deployed FactRegistry contract address.
VITE_FACT_REGISTRY_ADDRESS=0x0661d41d6495fa422105e5c1e3954f343a292fa0e824cd6a03cdc0794afd0777

# Backend relay base URL. The dev server proxies /api/* to this origin.
VITE_BACKEND_URL=http://localhost:8787